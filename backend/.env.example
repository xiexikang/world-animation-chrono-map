APP_PORT=8110
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=world_animation

# 白名单访问（生产环境建议开启）
WHITELIST_ENABLED=false
WHITELIST_IPS=127.0.0.1,::1
WHITELIST_ORIGINS=http://localhost:2500,http://127.0.0.1:2500
# 部署在 Nginx/网关后时设为 true，从 X-Forwarded-For / X-Real-IP 读取客户端 IP
TRUST_PROXY=false
